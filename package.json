{
  "name": "teacher-replacement-system",
  "version": "1.0.0",
  "description": "Система замены преподавателей в университете",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "init-db": "node init_db.js",
    "init-db:yes": "node init_db.js --yes",
    "migrate-subjects": "node -e \"require('./init_db').migrateSubjectNames().then(() => process.exit(0)).catch(e => { console.error(e); process.exit(1); })\"",
    "import-schedule": "node schedule-import.js",
    "test-email": "node test-email.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^8.0.7",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
